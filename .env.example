# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://hermes:hermes@localhost:5432/hermes
REDIS_URL=redis://localhost:6379/0

# ── Alpaca ────────────────────────────────────────────────────
# Paper trading keys from alpaca.markets → Paper Trading → API Keys
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_SECRET_KEY=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets

# Live keys (only used when ALPACA_MODE=live)
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=

# Set to "paper" or "live"
ALPACA_MODE=paper

# ── IBKR ─────────────────────────────────────────────────────
# Filled in at Phase 5 — IB Gateway connection
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=1

# ── Telegram ─────────────────────────────────────────────────
# @HermesTradeBot credentials — fill in at Phase 5
HERMES_TELEGRAM_BOT_TOKEN=
HERMES_TELEGRAM_CHAT_ID=

# ── App ───────────────────────────────────────────────────────
HERMES_ENV=development
HERMES_LOG_LEVEL=INFO
HERMES_PORT=8090

# Kill switch — set to "true" to halt all new orders immediately
HERMES_HALTED=false
